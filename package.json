{
  "name": "hono-react-fly-sqlite-template",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently \"pnpm --filter @starter/server dev\" \"pnpm --filter @starter/web dev\"",
    "build": "pnpm -r build",
    "check": "pnpm -r typecheck",
    "test": "pnpm --filter @starter/server test",
    "start": "pnpm --filter @starter/server start",
    "migrate": "pnpm --filter @starter/server migrate"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@google/stitch-sdk": "^0.0.3"
  }
}
