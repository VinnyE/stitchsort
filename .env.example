# Server
PORT=3000
DATABASE_URL=./app.sqlite
UPLOAD_DIR=./uploads
API_AUTH_ENABLED=false
API_AUTH_TOKEN=
API_AUTH_ALLOW_QUERY_PARAM=false
SESSION_COOKIE_NAME=app_session

# Optional object storage (Cloudflare R2 or any S3-compatible provider)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Litestream backup target for production
LITESTREAM_BUCKET=
LITESTREAM_ENDPOINT=
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
LITESTREAM_REPLICA_PATH=app.sqlite
